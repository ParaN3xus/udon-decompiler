{
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit",
      "source.organizeImports.biome": "explicit"
    }
  },
  "[csharp]": {
    "editor.defaultFormatter": "seaube.clangformat"
  },
  "clangFormat.executable.default": "${workspaceFolder}/node_modules/.bin/clang-format",
  "clangFormat.executable.windows": "${workspaceFolder}/node_modules/.bin/clang-format.cmd",
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "npm.packageManager": "yarn",
  "editor.formatOnSave": true,
  "tinymist.exportTarget": "html",
  "tinymist.lint.enabled": true,
  "tinymist.typstExtraArgs": ["--input", "x-target=html"]
}
